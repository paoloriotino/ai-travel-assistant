# Google Gemini API Key
GOOGLE_API_KEY=la_tua_chiave_api_gemini_qui
# Provider LLM: "google" (cloud) oppure "ollama" (locale)
LLM_PROVIDER=google
# Modello LLM Cloud: "gemini-1.5-pro" (Massima Qualità & Ragionamento) oppure "gemini-flash-latest" (Velocità)
# Modello LLM Locale (Ollama): "qwen2.5:14b", "gemma2:9b", o "llama3.1:8b"
LLM_MODEL=gemini-1.5-pro
# Indirizzo base per Ollama locale (usato solo se LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# (Opzionale) LangSmith Tracing & Monitoring
LANGCHAIN_TRACING_V2=true
# Usa https://eu.api.smith.langchain.com se il tuo account LangSmith è in regione Europa (EU)
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_API_KEY=la_tua_chiave_langsmith_qui
LANGCHAIN_PROJECT=ai-travel-assistant

